{
  "name": "ly-automation",
  "version": "1.0.0",
  "description": "拼多多自动上新",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.lyauto.automation",
    "productName": "乐羽",
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico",
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "乐羽",
      "runAfterFinish": true
    },
    "extraResources": [
      { "from": "../dist/app.jar",          "to": "app.jar"  },
      { "from": "../dist/runtime",          "to": "runtime"  },
      { "from": "../dist/frontend",         "to": "frontend" },
      { "from": "../商品标题库.xlsx",        "to": "商品标题库.xlsx" },
      { "from": "../产品信息填写参考.xlsx",    "to": "产品信息填写参考.xlsx" },
      { "from": "../tools/pdd_listing.js",  "to": "tools/pdd_listing.js" },
      { "from": "../tools/node",            "to": "tools/node"           },
      { "from": "../tools/node_modules",    "to": "tools/node_modules"   },
      { "from": "../tools/browsers",        "to": "tools/browsers"       },
      { "from": "../tools", "to": ".", "filter": ["vc_redist.x64.exe"] }
    ],
    "directories": {
      "output": "../dist-electron"
    }
  }
}
